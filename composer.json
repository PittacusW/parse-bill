{
  "name": "pittacusw/parse-bill",
  "description": "Wrapper to parse XML Bills and generate a PDF file",
  "keywords": [
    "laravel",
    "touchef"
  ],
  "license": "LGPL-3.0",
  "authors": [
    {
      "name": "Touchef",
      "email": "contacto@touchef.cl"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "pittacusw/core": "*",
    "barryvdh/laravel-dompdf": "*",
    "freshwork/chilean-bundle": "*",
    "laravel/framework": "*",
    "neitanod/forceutf8": "*",
    "spatie/laravel-package-tools": "*",
    "milon/barcode": "*",
    "spatie/array-to-xml": "*"
  },
  "autoload": {
    "psr-0": {
      "Pittacusw\\ParseBill": "src/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pittacusw\\ParseBill\\ParseBillServiceProvider"
      ]
    }
  }
}
